# Public service identity / URL
SERVICE_DID=did:web:deco.mu.social
PUBLIC_URL=https://deco.mu.social
ALLOWED_ORIGIN=https://mu.social
PLC_DIRECTORY_URL=https://plc.eurosky.network

# Mollie test mode first; switch to a live key only after end-to-end testing.
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_AMOUNT=3.00
MOLLIE_CURRENCY=EUR
MOLLIE_DESCRIPTION=Eurosky+ subscription
BILLING_MONTHS=1
CHECKOUT_REDIRECT_URL=https://mu.social/settings/decorations?checkout=return

# Official decoration grant issuer account.
DECO_ISSUER_PDS_URL=https://eurosky.social
DECO_ISSUER_IDENTIFIER=plus.mu.social
DECO_ISSUER_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
DECO_ISSUER_DID=did:plc:replace-me
DECO_SUBSCRIBER_LIST_URI=at://did:plc:replace-me/app.bsky.graph.list/replace-me

# Bunny Database / libSQL. Without DB_URL the dev server uses memory only.
DB_URL=libsql://replace-me
DB_TOKEN=replace-me

# Daily sweep authentication and post-payment grace period.
SWEEP_SECRET=replace-with-a-long-random-value
GRACE_DAYS=5

# Local smoke tests only. Never set this in production.
# DEV_TRUST_DID_HEADER=1
