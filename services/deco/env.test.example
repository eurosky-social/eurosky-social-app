# Isolated Bunny deployment for Mollie test mode.
SERVICE_DID=did:web:test.deco.mu.social
PUBLIC_URL=https://test.deco.mu.social
ALLOWED_ORIGIN=https://staging.mu.social
PLC_DIRECTORY_URL=https://plc.eurosky.network

MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_AMOUNT=3.00
MOLLIE_CURRENCY=EUR
MOLLIE_DESCRIPTION=Eurosky+ test subscription
BILLING_MONTHS=1
CHECKOUT_REDIRECT_URL=https://staging.mu.social/settings/decorations?checkout=return

# The test and production lists may belong to the same account. Only this exact
# list is changed by the test service.
DECO_ISSUER_PDS_URL=https://eurosky.social
DECO_ISSUER_IDENTIFIER=decorations.mu.social
DECO_ISSUER_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
DECO_ISSUER_DID=did:plc:replace-me
DECO_SUBSCRIBER_LIST_URI=at://did:plc:replace-me/app.bsky.graph.list/test-list-rkey

# Always use a database and sweep secret separate from production.
DB_URL=libsql://replace-with-test-database
DB_TOKEN=replace-with-test-token
SWEEP_SECRET=replace-with-test-sweep-secret
GRACE_DAYS=5

# Staging web build values (set in the build/deploy environment, not Bunny):
# EXPO_PUBLIC_DECO_ENABLED=true
# EXPO_PUBLIC_DECO_SERVICE_URL=https://test.deco.mu.social
# EXPO_PUBLIC_DECO_SERVICE_DID=did:web:test.deco.mu.social
# EXPO_PUBLIC_DECO_MANAGE_URL=https://staging.mu.social/settings/decorations
# EXPO_PUBLIC_DECO_SUBSCRIBER_LIST_URIS=at://did:plc:replace-me/app.bsky.graph.list/test-list-rkey
