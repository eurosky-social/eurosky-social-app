{
  "lexicon": 1,
  "id": "social.mu.deco.cancel",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Cancels renewal while preserving decorations through the paid period.",
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["active", "cancelAtPeriodEnd", "plan"],
          "properties": {
            "active": { "type": "boolean" },
            "paidUntil": { "type": "string", "format": "datetime" },
            "cancelAtPeriodEnd": { "type": "boolean" },
            "plan": { "ref": "#plan" }
          }
        }
      },
      "errors": [{ "name": "SubscriptionInactive" }]
    },
    "plan": {
      "type": "object",
      "required": ["amount", "currency", "billingMonths"],
      "properties": {
        "amount": { "type": "string" },
        "currency": { "type": "string" },
        "billingMonths": { "type": "integer", "minimum": 1, "maximum": 12 }
      }
    }
  }
}
